<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package Name="$(var.name) $(var.major).$(var.minor).$(var.point)"
           Manufacturer="Open Identity Platform Community"
           Version="$(var.major).$(var.minor).$(var.point)"
           UpgradeCode="A3E82AC0-88E6-4DEE-9D8C-5AE3B7853274"
           Language="1033" Codepage="1252" InstallerVersion="500" Scope="perMachine">

    <SummaryInformation Description="Open Identity Platform Community products"
                        Manufacturer="Open Identity Platform Community"/>

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed."/>
    <MediaTemplate EmbedCab="yes" CompressionLevel="high"/>

    <Property Id="ARPHELPLINK" Value="https://github.com/OpenIdentityPlatform/OpenDJ/wiki"/>

    <!-- Upgrade path detection: install over an existing OpenDJ instead of the default.
         Order matters - the last successful search wins: the registry value written by this
         package (custom paths, new installs) beats the legacy x86 default directory
         ([ProgramFilesFolder] is Program Files (x86) in an x64 package). The result is applied
         only when OPENDJ was not set explicitly (command line / UI). -->
    <Property Id="OPENDJ_DETECTED" Secure="yes">
      <DirectorySearch Id="LegacyX86InstallDir" Path="[ProgramFilesFolder]$(var.name)"/>
      <RegistrySearch Id="InstallDirRegistrySearch" Root="HKLM" Key="SOFTWARE\$(var.name)"
                      Name="InstallDir" Type="directory"/>
    </Property>
    <SetProperty Id="OPENDJ" After="AppSearch" Sequence="both" Value="[OPENDJ_DETECTED]"
                 Condition="OPENDJ_DETECTED AND NOT OPENDJ"/>

    <!-- The server needs a JRE (11+) which this package does not ship: refuse to install when
         none is detectable. Signals: %JAVA_HOME%\bin\java.exe, or java-looking entries on PATH
         (an MSI cannot scan PATH for java.exe, so this is a substring heuristic).
         'Installed' keeps repair/uninstall working. -->
    <Property Id="JAVAHOME_JAVA">
      <DirectorySearch Id="JavaHomeEnvDir" Path="[%JAVA_HOME]" Depth="0">
        <DirectorySearch Id="JavaHomeBinDir" Path="bin" Depth="0">
          <FileSearch Id="JavaHomeJavaExe" Name="java.exe"/>
        </DirectorySearch>
      </DirectorySearch>
    </Property>
    <Launch Condition="Installed OR JAVAHOME_JAVA OR (%PATH ~&gt;&lt; &quot;java&quot;) OR (%PATH ~&gt;&lt; &quot;jdk&quot;) OR (%PATH ~&gt;&lt; &quot;jre&quot;) OR (%PATH ~&gt;&lt; &quot;zulu&quot;)"
            Message="[ProductName] requires Java (JRE 11 or later), which is not installed by this package. Install a JRE, for example Eclipse Temurin from https://adoptium.net, or set the JAVA_HOME environment variable to your Java installation, or make sure the java executable is on the PATH, then run the installer again."/>

    <!-- The legacy windows-service.bat service is registered with key name = display name =
         "OpenDJ Server" (not MSI-managed). It points at the old install and its display name
         collides with the ServiceInstall below, so drop it before InstallServices. -->
    <CustomAction Id="RemoveLegacyService" Directory="OPENDJ"
                  ExeCommand="cmd.exe /c (net stop &quot;OpenDJ Server&quot; &amp; sc delete &quot;OpenDJ Server&quot;)"
                  Execute="deferred" Impersonate="no" Return="ignore"/>
    <InstallExecuteSequence>
      <Custom Action="RemoveLegacyService" Before="InstallServices" Condition="NOT Installed"/>
    </InstallExecuteSequence>

    <!-- UI customization -->
    <WixVariable Id="WixUIBannerBmp" Value="opendjbanner.bmp"/>
    <WixVariable Id="WixUIDialogBmp" Value="opendjdialog.bmp"/>

    <!-- x64 install location: C:\Program Files\OpenDJ -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="OPENDJ" Name="$(var.name)">
        <Directory Id="OPENDJ_LIB" Name="lib"/>
      </Directory>
    </StandardDirectory>

    <!-- Windows service: opendj_service.exe is the SCM wrapper that runs bat\start-ds.bat.
         Registered here, but NOT started during install (the instance must be configured by
         setup.bat first). -->
    <Component Id="OpenDJServiceExe" Directory="OPENDJ_LIB">
      <File Id="opendj_service.exe" Source="$(var.serviceExe)" KeyPath="yes"/>
      <ServiceInstall Id="OpenDJService" Name="OpenDJ" DisplayName="OpenDJ Server"
                      Description="OpenDJ LDAPv3 Directory Server" Type="ownProcess"
                      Start="auto" ErrorControl="normal"
                      Arguments="start &quot;[OPENDJ]&quot;" Vital="no"/>
      <ServiceControl Id="OpenDJServiceControl" Name="OpenDJ"
                      Stop="both" Remove="uninstall" Wait="yes"/>
    </Component>

    <!-- Remember the install location so upgrades land in the same directory. -->
    <Component Id="InstallDirRegistry" Directory="OPENDJ">
      <RegistryValue Root="HKLM" Key="SOFTWARE\$(var.name)" Name="InstallDir"
                     Type="string" Value="[OPENDJ]" KeyPath="yes"/>
    </Component>

    <!-- Harvest the payload. Exclusions are already applied during staging (Ant), so each
         <Files> needs only the Include attribute (WiX 5 requires it; no Exclude here):
         stagingRoot has everything except lib; stagingLib has lib minus the service wrapper. -->
    <ComponentGroup Id="OpenDJRoot" Directory="OPENDJ">
      <Files Include="$(var.stagingRoot)\**"/>
    </ComponentGroup>
    <ComponentGroup Id="OpenDJLib" Directory="OPENDJ_LIB">
      <Files Include="$(var.stagingLib)\**"/>
    </ComponentGroup>

    <Feature Id="All" Title="Server and tools" ConfigurableDirectory="OPENDJ">
      <ComponentRef Id="OpenDJServiceExe"/>
      <ComponentRef Id="InstallDirRegistry"/>
      <ComponentGroupRef Id="OpenDJRoot"/>
      <ComponentGroupRef Id="OpenDJLib"/>
    </Feature>

    <!-- WixUI_InstallDir; the license is shown only by setup, not by this installer. -->
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="OPENDJ"/>
  </Package>
</Wix>
